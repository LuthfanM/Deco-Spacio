# Pollinations image generation endpoint.
POLLINATIONS_IMAGE_BASE_URL="https://gen.pollinations.ai/image"

# Optional Pollinations model override. Leave empty to use the service default.
POLLINATIONS_MODEL="flux"

# get it from pollinations website
POLLINATIONS_KEY=""

# Optional referrer identifier passed to Pollinations.
POLLINATIONS_REFERRER="deco-spacio-ai"

# Generated image dimensions.
POLLINATIONS_WIDTH="1024"
POLLINATIONS_HEIGHT="800"

# Hide Pollinations logo/watermark when supported.
POLLINATIONS_NO_LOGO="true"

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Optional fallback header values for Supabase RLS.
# Runtime user-specific requests pass these dynamically.
SUPABASE_DECO_SPACIO_USER_ID=
SUPABASE_DECO_SPACIO_RECOVERY_KEY=
